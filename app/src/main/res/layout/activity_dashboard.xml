<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ems_charcoal"
    tools:context=".DashboardActivity">

    <!-- Title -->
    <TextView
        android:id="@+id/dashboardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.15"
        android:text="@string/dashboard_title"
        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Accent divider -->
    <View
        android:id="@+id/dashboardAccent"
        android:layout_width="60dp"
        android:layout_height="3dp"
        android:layout_marginTop="16dp"
        android:background="@color/ems_accent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dashboardTitle" />

    <!-- Indoor Storage Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardIndoorStorage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="24dp"
        app:cardBackgroundColor="@color/ems_dark_gray"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dashboardAccent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif"
                android:text="@string/category_indoor_storage"
                android:textColor="@color/white"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/countIndoorStorage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/ems_accent"
                android:textSize="24sp"
                tools:text="0" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Camper and Boat Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCamperBoat"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="24dp"
        app:cardBackgroundColor="@color/ems_dark_gray"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardIndoorStorage">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif"
                android:text="@string/category_camper_boat"
                android:textColor="@color/white"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/countCamperBoat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/ems_accent"
                android:textSize="24sp"
                tools:text="0" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- RV Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="24dp"
        app:cardBackgroundColor="@color/ems_dark_gray"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardCamperBoat">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif"
                android:text="@string/category_rv"
                android:textColor="@color/white"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/countRv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/ems_accent"
                android:textSize="24sp"
                tools:text="0" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Open Keybox button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/openKeyboxButton"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:layout_marginTop="32dp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.12"
        android:text="@string/open_keybox"
        android:textColor="@color/ems_charcoal"
        android:textSize="15sp"
        app:backgroundTint="@color/ems_accent"
        app:cornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardRv" />

    <!-- Rent a Unit button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/rentUnitButton"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.12"
        android:text="@string/rent_a_unit"
        android:textColor="@color/ems_charcoal"
        android:textSize="15sp"
        app:backgroundTint="@color/ems_accent"
        app:cornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/openKeyboxButton" />

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/dashboardProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/ems_accent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Error text -->
    <TextView
        android:id="@+id/dashboardError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="40dp"
        android:gravity="center"
        android:textColor="#FFE57373"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rentUnitButton"
        tools:text="Error message"
        tools:visibility="visible" />

    <!-- Logout button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/logoutButton"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:layout_marginBottom="48dp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.12"
        android:text="@string/logout"
        android:textColor="@color/white"
        android:textSize="15sp"
        app:cornerRadius="24dp"
        app:strokeColor="@color/ems_accent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
